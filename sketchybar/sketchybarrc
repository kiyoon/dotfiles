#!/usr/bin/env bash
# SketchyBar config, integrated with AeroSpace (see aerospace/aerospace.toml
# exec-on-workspace-change). Workspaces here are dynamic: items space.1..30 are
# pre-created hidden and toggled by plugins/aerospace_workspaces.sh.

source "$CONFIG_DIR/colors.sh"
PLUGIN_DIR="$CONFIG_DIR/plugins"

FONT="JetBrainsMono Nerd Font"

# Compiled helpers (committed as .swift, binary gitignored, built on demand).
HELPER_DIR="$CONFIG_DIR/helpers"
[[ -x "$HELPER_DIR/tis_current" ]] || \
	swiftc -O "$HELPER_DIR/tis_current.swift" -o "$HELPER_DIR/tis_current" 2>/dev/null

# ---- Bar ----
sketchybar --bar \
	position=top \
	height=36 \
	display=all \
	sticky=on \
	padding_left=10 \
	padding_right=10 \
	blur_radius=20 \
	color=$BAR_COLOR

# ---- Defaults ----
sketchybar --default \
	padding_left=4 \
	padding_right=4 \
	icon.font="$FONT:Bold:13.0" \
	icon.color=$LABEL_COLOR \
	icon.padding_left=8 \
	icon.padding_right=4 \
	label.font="$FONT:Medium:12.0" \
	label.color=$LABEL_COLOR \
	label.padding_left=2 \
	label.padding_right=8 \
	background.color=$ITEM_BG_COLOR \
	background.corner_radius=6 \
	background.height=24 \
	background.drawing=off

# ---- Restart menu (leftmost): one button whose popup restarts sketchybar or
# AeroSpace -- recovery for when a monitor change wedges them. `sketchybar
# --reload` rebuilds the bar in place; AeroSpace is fully relaunched (not
# `reload-config`, which can't revive a hung server) and its after-startup
# command re-triggers the workspace refresh. Popup closes on selection and when
# the pointer leaves it (mouse.exited.global); rows highlight on hover
# (popup_hover.sh); row actions live in plugins/restart_action.sh.
sketchybar --add item restart left \
	--set restart \
	icon=󰜉 \
	icon.color=$LABEL_COLOR \
	label.drawing=off \
	background.drawing=on \
	popup.background.color=$ITEM_BG_COLOR \
	popup.background.corner_radius=6 \
	popup.background.border_width=1 \
	popup.background.border_color=$MUTED_COLOR \
	popup.background.shadow.drawing=on \
	popup.blur_radius=20 \
	popup.align=left \
	popup.y_offset=-1 \
	click_script="sketchybar --set restart popup.drawing=toggle" \
	script="sketchybar --set restart popup.drawing=off" \
	--subscribe restart mouse.exited.global

# Shared look for the two menu rows (label set per item below).
restart_row=(
	icon=󰜉
	icon.color=$LABEL_COLOR
	icon.padding_left=10
	icon.padding_right=6
	label.color=$LABEL_COLOR
	label.padding_right=14
	width=150
	align=left
	background.corner_radius=6
	background.height=22
	background.color=$ACCENT_COLOR
	background.drawing=off
)

sketchybar --add item restart.sketchybar popup.restart \
	--set restart.sketchybar "${restart_row[@]}" \
	label="sketchybar" \
	script="$PLUGIN_DIR/popup_hover.sh" \
	click_script="$PLUGIN_DIR/restart_action.sh sketchybar" \
	--subscribe restart.sketchybar mouse.entered mouse.exited

sketchybar --add item restart.aerospace popup.restart \
	--set restart.aerospace "${restart_row[@]}" \
	label="AeroSpace" \
	script="$PLUGIN_DIR/popup_hover.sh" \
	click_script="$PLUGIN_DIR/restart_action.sh aerospace" \
	--subscribe restart.aerospace mouse.entered mouse.exited

# ---- Prompts menu (next to restart): one button whose popup types a saved
# prompt into the focused app. Rows are generated from Hammerspoon's
# PromptList() -- single source of truth in hammerspoon/init.lua -- and each row
# types its prompt via `hs -c PastePrompt(id)` (keystroke simulation, so Claude
# Code keeps it inline instead of a [Pasted text] attachment). Add prompts in
# init.lua, then reload Hammerspoon + sketchybar. Same popup UX as restart. ----
sketchybar --add item prompts left \
	--set prompts \
	icon=󰚩 \
	icon.color=$LABEL_COLOR \
	label.drawing=off \
	background.drawing=on \
	popup.background.color=$ITEM_BG_COLOR \
	popup.background.corner_radius=6 \
	popup.background.border_width=1 \
	popup.background.border_color=$MUTED_COLOR \
	popup.background.shadow.drawing=on \
	popup.blur_radius=20 \
	popup.align=left \
	popup.y_offset=-1 \
	click_script="sketchybar --set prompts popup.drawing=toggle" \
	script="sketchybar --set prompts popup.drawing=off" \
	--subscribe prompts mouse.exited.global

# Shared row look (label set per prompt below).
prompt_row=(
	icon=󰚩
	icon.color=$LABEL_COLOR
	icon.padding_left=10
	icon.padding_right=6
	label.color=$LABEL_COLOR
	label.padding_right=16
	background.corner_radius=6
	background.height=22
	background.color=$ACCENT_COLOR
	background.drawing=off
)

# One popup row per registered prompt ("id<TAB>label" lines from Hammerspoon).
# If Hammerspoon is down at load, show a hint row instead of an empty menu.
prompt_rows="$(hs -c 'return PromptList()' 2>/dev/null)"
if [[ -n "$prompt_rows" ]]; then
	while IFS=$'\t' read -r pid plabel; do
		[[ -z "$pid" ]] && continue
		sketchybar --add item "prompt.$pid" popup.prompts \
			--set "prompt.$pid" "${prompt_row[@]}" \
			label="$plabel" \
			script="$PLUGIN_DIR/popup_hover.sh" \
			click_script="$PLUGIN_DIR/prompt_action.sh $pid" \
			--subscribe "prompt.$pid" mouse.entered mouse.exited
	done <<<"$prompt_rows"
else
	sketchybar --add item prompt.__none popup.prompts \
		--set prompt.__none icon.padding_left=10 label="(Hammerspoon not running)" \
		label.color=$MUTED_COLOR label.padding_right=16
fi

# ---- Displays menu (next to prompts): move the focused window between monitors.
# Rows mirror the existing AeroSpace bindings (⌥⇧A / ⌥⇧T -> scripts/monitor.sh),
# so the shortcut is on-screen to memorize; clicking runs the same toggle (to the
# external display, or back to built-in if the window is already there). ----
sketchybar --add item displays left \
	--set displays \
	icon=󰍺 \
	icon.color=$LABEL_COLOR \
	label.drawing=off \
	background.drawing=on \
	popup.background.color=$ITEM_BG_COLOR \
	popup.background.corner_radius=6 \
	popup.background.border_width=1 \
	popup.background.border_color=$MUTED_COLOR \
	popup.background.shadow.drawing=on \
	popup.blur_radius=20 \
	popup.align=left \
	popup.y_offset=-1 \
	click_script="sketchybar --set displays popup.drawing=toggle" \
	script="sketchybar --set displays popup.drawing=off" \
	--subscribe displays mouse.exited.global

# Shared row look; label leads with the keyboard shortcut (to memorize) then the
# action. icon off so popup_hover.sh's icon-color reset stays a no-op.
display_row=(
	icon.drawing=off
	label.color=$LABEL_COLOR
	label.padding_left=10
	label.padding_right=16
	background.corner_radius=6
	background.height=22
	background.color=$ACCENT_COLOR
	background.drawing=off
)

sketchybar --add item display.left popup.displays \
	--set display.left "${display_row[@]}" \
	label="⌥⇧A    Move window → left display" \
	script="$PLUGIN_DIR/popup_hover.sh" \
	click_script="$PLUGIN_DIR/display_action.sh left" \
	--subscribe display.left mouse.entered mouse.exited

sketchybar --add item display.right popup.displays \
	--set display.right "${display_row[@]}" \
	label="⌥⇧T    Move window → right display" \
	script="$PLUGIN_DIR/popup_hover.sh" \
	click_script="$PLUGIN_DIR/display_action.sh right" \
	--subscribe display.right mouse.entered mouse.exited

# ---- AeroSpace mode badge (left of workspaces, hidden in main mode) ----
# Fired by the mode-switching keybindings in aerospace.toml.
sketchybar --add event aerospace_mode_change

sketchybar --add item aero_mode left \
	--set aero_mode \
	drawing=off \
	updates=on \
	icon.drawing=off \
	label.font="$FONT:Bold:11.0" \
	label.padding_left=8 \
	label.padding_right=8 \
	background.drawing=on \
	script="$PLUGIN_DIR/mode.sh" \
	--subscribe aero_mode aerospace_mode_change forced

# ---- AeroSpace workspaces (left) ----
# Fired by aerospace's exec-on-workspace-change.
sketchybar --add event aerospace_workspace_change

# Pre-create all 30 possible workspace items hidden; the listener plugin
# toggles drawing + highlight. No add/remove churn -> stable order, no flicker.
space_args=()
for sid in $(seq 1 30); do
	space_args+=(
		--add item "space.$sid" left
		--set "space.$sid"
		drawing=off
		icon="$sid"
		icon.padding_left=9
		icon.padding_right=4
		label.drawing=off
		label.font="sketchybar-app-font:Regular:15.0"
		label.padding_left=0
		label.padding_right=9
		background.drawing=on
		click_script="/opt/homebrew/bin/aerospace workspace $sid"
	)
done
sketchybar "${space_args[@]}"

# Thin separators between per-monitor workspace groups (multi-monitor only).
# The listener's --reorder positions them; single monitor keeps them hidden.
divider_args=()
for d in 1 2 3; do
	divider_args+=(
		--add item "divider.$d" left
		--set "divider.$d"
		drawing=off
		icon="│"
		icon.color=$MUTED_COLOR
		icon.padding_left=2
		icon.padding_right=2
		label.drawing=off
	)
done
sketchybar "${divider_args[@]}"

# Hidden listener that rebuilds workspace visibility on every change.
# updates=on so it keeps receiving events while drawing=off.
sketchybar --add item aerospace_listener left \
	--set aerospace_listener \
	drawing=off \
	updates=on \
	script="$PLUGIN_DIR/aerospace_workspaces.sh" \
	--subscribe aerospace_listener aerospace_workspace_change forced \
	system_woke display_change space_windows_change

# ---- Front app (left) ----
sketchybar --add item front_app left \
	--set front_app \
	icon.drawing=off \
	label.font="$FONT:Bold:12.0" \
	label.padding_left=8 \
	script="$PLUGIN_DIR/front_app.sh" \
	--subscribe front_app front_app_switched forced

# ---- Right side: clock | battery | volume | bluetooth | wifi ----
# Tighter spacing than the defaults for the small status items (battery,
# volume, bluetooth, wifi, cpu, gpu, ram), which otherwise carry 30px of padding each.
compact=(
	padding_left=2 padding_right=2
	icon.padding_left=4 icon.padding_right=2
	label.padding_left=2 label.padding_right=4
)

sketchybar --add item clock right \
	--set clock \
	update_freq=10 \
	icon=󰃰 \
	background.drawing=on \
	click_script="open -a Calendar" \
	script="$PLUGIN_DIR/clock.sh"

sketchybar --add item battery right \
	--set battery \
	"${compact[@]}" \
	update_freq=120 \
	click_script="open 'x-apple.systempreferences:com.apple.Battery-Settings.extension'" \
	script="$PLUGIN_DIR/battery.sh" \
	--subscribe battery power_source_change system_woke

sketchybar --add item volume right \
	--set volume \
	"${compact[@]}" \
	click_script="$PLUGIN_DIR/volume_click.sh" \
	script="$PLUGIN_DIR/volume.sh" \
	--subscribe volume volume_change forced

sketchybar --add event bluetooth_change "com.apple.bluetooth.status" \
	--add event bluetooth_on "IOBluetoothHostControllerPoweredOnNotification" \
	--add event bluetooth_off "IOBluetoothHostControllerPoweredOffNotification"

sketchybar --add item bluetooth_boucles right \
	--set bluetooth_boucles \
	"${compact[@]}" \
	click_script="$PLUGIN_DIR/bluetooth_click.sh" \
	script="$PLUGIN_DIR/bluetooth_boucles.sh" \
	--subscribe bluetooth_boucles bluetooth_change bluetooth_on bluetooth_off system_woke forced

sketchybar --add item wifi right \
	--set wifi \
	"${compact[@]}" \
	update_freq=30 \
	click_script="open 'x-apple.systempreferences:com.apple.wifi-settings-extension'" \
	script="$PLUGIN_DIR/wifi.sh" \
	--subscribe wifi wifi_change system_woke

# ---- System stats: cpu | gpu | ram (left of wifi) ----
# Right-position items stack right-to-left, so add order here is reversed.
sketchybar --add item ram right \
	--set ram \
	"${compact[@]}" \
	update_freq=10 \
	icon=󰍛 \
	icon.color=$MUTED_COLOR \
	click_script="open -a 'Activity Monitor'" \
	script="$PLUGIN_DIR/ram.sh"

sketchybar --add item gpu right \
	--set gpu \
	"${compact[@]}" \
	update_freq=5 \
	icon=󰢮 \
	icon.color=$MUTED_COLOR \
	click_script="open -a 'Activity Monitor'" \
	script="$PLUGIN_DIR/gpu.sh"

sketchybar --add item cpu right \
	--set cpu \
	"${compact[@]}" \
	update_freq=5 \
	icon=󰘚 \
	icon.color=$MUTED_COLOR \
	click_script="open -a 'Activity Monitor'" \
	script="$PLUGIN_DIR/cpu.sh"

# ---- Menu bar app aliases (left of the stats) ----
# Screen captures of the real macOS menu bar items, so they need Screen
# Recording permission for sketchybar (System Settings -> Privacy & Security),
# then a sketchybar restart. The app must be running with its item in the
# real menu bar (hidden behind the notch is fine, removed is not).
# On this macOS every status item is hosted by Control Center, under the
# *localized* app name (CC_OWNER: update it if the system language changes).
# Each app registers two windows: a transparent bundle-id-named host plus a
# content window named by the item's autosave name -- alias the latter
# (found empirically; list candidates: sketchybar --query default_menu_items).
# AeroSpace and TextInputMenuAgent are exceptions: there the bundle-id window
# holds the content.
# Right-position items stack right-to-left, so add order here is reversed.
# alias.color tints the capture to match the theme (all four are monochrome).
CC_OWNER="Centre de contrôle"

# Input method (한/A): native item, deliberately NOT an alias. macOS draws
# the input icon in different windows per source type (method vs layout), only
# the active display's copy renders, and the plain-layout window is anonymous
# with a drifting identity -- no capture survives a source switch (verified by
# pixel-probing). Event-driven via helpers/input_watcher: the OS's own
# input-switch distributed notifications no longer fire on this macOS (tested
# with real switches), so the watcher daemon polls the TIS API in-process at
# 150ms (negligible CPU, no process spawns) and triggers input_change only on
# actual changes, passing INPUT_SOURCE_ID. update_freq is just a safety net.
# Drawn as a pill so it is big enough to click; clicking pops the real
# menu bar dropdown.
sketchybar --add event input_change

sketchybar --add item input_method right \
	--set input_method \
	padding_left=2 \
	padding_right=2 \
	update_freq=60 \
	icon.drawing=off \
	label.font="$FONT:Bold:13.0" \
	label.padding_left=7 \
	label.padding_right=7 \
	background.drawing=on \
	click_script="$PLUGIN_DIR/alias_click.sh TextInputMenuAgent input" \
	script="$PLUGIN_DIR/input_source.sh" \
	--subscribe input_method input_change

killall input_watcher 2>/dev/null
[[ -x "$HELPER_DIR/input_watcher" ]] || \
	swiftc -O "$HELPER_DIR/input_watcher.swift" -o "$HELPER_DIR/input_watcher" 2>/dev/null
"$HELPER_DIR/input_watcher" &

# Instant re-capture when the user toggles Amphetamine: amphetamine_click.sh
# fires this event right after the AppleScript toggle, so the icon flips without
# waiting for the 3s poll (which stays as the backstop for external changes).
sketchybar --add event amphetamine_change

sketchybar --add alias "$CC_OWNER,Amphetamine" right \
	--rename "$CC_OWNER,Amphetamine" amphetamine \
	--set amphetamine \
	update_freq=3 \
	click_script="$PLUGIN_DIR/amphetamine_click.sh" \
	padding_left=-9 \
	padding_right=-9 \
	alias.color=$LABEL_COLOR \
	--subscribe amphetamine amphetamine_change

sketchybar --add alias "$CC_OWNER,codexbar-merged" right \
	--rename "$CC_OWNER,codexbar-merged" codexbar \
	--set codexbar \
	update_freq=10 \
	click_script="$PLUGIN_DIR/alias_click.sh CodexBar Codex" \
	padding_left=-9 \
	padding_right=-9 \
	alias.color=$LABEL_COLOR

# ---- Finalize ----
sketchybar --update
